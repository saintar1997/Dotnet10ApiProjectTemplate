# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Database
ConnectionStrings__DefaultConnection=Server=YOUR_SERVER;Database=YOUR_DATABASE;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=True;

# JWT
Jwt__Key=YOUR_STRONG_SECRET_KEY_AT_LEAST_32_CHARS
Jwt__Issuer=EnterpriseWeb.API
Jwt__Audience=EnterpriseWeb.Clients
Jwt__ExpiresInMinutes=60

# Seq (Optional)
Seq__ServerUrl=http://localhost:5341

# Rate Limiting
RateLimiting__Global__PermitLimit=100
RateLimiting__Global__WindowMinutes=1
RateLimiting__AuthStrict__PermitLimit=10
RateLimiting__AuthStrict__WindowMinutes=1
